# Template de variáveis de ambiente.
# Copie este arquivo para .env.local (que NÃO vai pro Git) e preencha com seus valores reais.
# Em produção, configure essas mesmas variáveis em:
#   Vercel → Project Settings → Environment Variables (Production + Preview + Development)

# === Duck Oficial / Duckfy (gateway de pagamento) ===
DUCK_PUBLIC_KEY=cole_sua_public_key_aqui
DUCK_SECRET_KEY=cole_sua_secret_key_aqui
DUCK_WORKSPACE_ID=cole_seu_workspace_id_aqui
